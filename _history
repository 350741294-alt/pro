. . . . 4 . . . \n. . . . . . . . \n`</field><data>{\"commentRefs\":[],\"fieldData\":{\"img\":null}}</data></shadow></value><value name=\"vx\"><shadow type=\"spriteSpeedPicker\"><field name=\"speed\">0</field></shadow></value><value name=\"vy\"><shadow type=\"spriteSpeedPicker\"><field name=\"speed\">-180</field></shadow></value></block></value><next><block type=\"spritesetpos\"><value name=\"sprite\"><block type=\"variables_get\"><field name=\"VAR\" id=\"aXb*3{8p;#$`5oA^CQaB\">laser</field></block></value><value name=\"x\"><shadow type=\"positionPicker\"><field name=\"index\">0</field></shadow><block type=\"Sprite_blockCombine_get\"><field name=\"property\">Sprite.x</field><value name=\"mySprite\"><block type=\"variables_get\"><field name=\"VAR\" id=\"B%;!ur)@z7ziNS?;7_%(\">playerShip</field></block></value></block></value><value name=\"y\"><shadow type=\"positionPicker\"><field name=\"index\">0</field></shadow><block type=\"math_arithmetic\"><field name=\"OP\">MINUS</field><value name=\"A\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"Sprite_blockCombine_get\"><field name=\"property\">Sprite.y</field><value name=\"mySprite\"><block type=\"variables_get\"><field name=\"VAR\" id=\"B%;!ur)@z7ziNS?;7_%(\">playerShip</field></block></value></block></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">8</field></shadow></value></block></value></block></next></block></statement></block><block type=\"spritesoverlap\" x=\"20\" y=\"499\"><comment pinned=\"false\" h=\"80\" w=\"160\">--- 💥 HARDCORE COLLISION HANDLERS ---</comment><value name=\"HANDLER_DRAG_PARAM_sprite\"><block type=\"argument_reporter_custom\" deletable=\"false\"><mutation typename=\"Sprite\"></mutation><field name=\"VALUE\">laser</field></block></value><value name=\"kind\"><shadow type=\"spritekind\"><field name=\"MEMBER\">Projectile</field></shadow></value><value name=\"HANDLER_DRAG_PARAM_otherSprite\"><block type=\"argument_reporter_custom\" deletable=\"false\"><mutation typename=\"Sprite\"></mutation><field name=\"VALUE\">meteor</field></block></value><value name=\"otherKind\"><shadow type=\"spritekind\"><field name=\"MEMBER\">Enemy</field></shadow></value><statement name=\"HANDLER\"><block type=\"spritedestroy\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" _expanded=\"0\" _input_init=\"true\"></mutation><field name=\"effect\">effects.spray</field><value name=\"sprite\"><block type=\"variables_get\"><field name=\"VAR\" id=\"aXb*3{8p;#$`5oA^CQaB\">laser</field></block></value><next><block type=\"spritedestroy\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" _expanded=\"2\" _input_init=\"true\"></mutation><field name=\"effect\">effects.disintegrate</field><value name=\"sprite\"><block type=\"variables_get\"><field name=\"VAR\" id=\"CrlTi;,7[.[_eGE#bncO\">meteor</field></block></value><value name=\"duration\"><shadow type=\"timePicker\"><field name=\"ms\">200</field></shadow></value><next><block type=\"hudChangeScoreBy\"><value name=\"value\"><shadow type=\"math_number\"><field name=\"NUM\">10</field></shadow></value></block></next></block></next></block></statement></block><block type=\"spritesoverlap\" x=\"798\" y=\"499\"><value name=\"HANDLER_DRAG_PARAM_sprite\"><block type=\"argument_reporter_custom\" deletable=\"false\"><mutation typename=\"Sprite\"></mutation><field name=\"VALUE\">player</field></block></value><value name=\"kind\"><shadow type=\"spritekind\"><field name=\"MEMBER\">Player</field></shadow></value><value name=\"HANDLER_DRAG_PARAM_otherSprite\"><block type=\"argument_reporter_custom\" deletable=\"false\"><mutation typename=\"Sprite\"></mutation><field name=\"VALUE\">meteor</field></block></value><value name=\"otherKind\"><shadow type=\"spritekind\"><field name=\"MEMBER\">Enemy</field></shadow></value><statement name=\"HANDLER\"><block type=\"spritedestroy\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" _expanded=\"2\" _input_init=\"true\"></mutation><field name=\"effect\">effects.fire</field><value name=\"sprite\"><block type=\"variables_get\"><field name=\"VAR\" id=\"CrlTi;,7[.[_eGE#bncO\">meteor</field></block></value><value name=\"duration\"><shadow type=\"timePicker\"><field name=\"ms\">200</field></shadow></value><next><block type=\"camerashake\"><comment pinned=\"false\" h=\"80\" w=\"160\">Bigger screen shake for maximum panic!</comment><value name=\"amplitude\"><shadow type=\"math_number_minmax\"><mutation min=\"1\" max=\"8\" precision=\"0\"></mutation><field name=\"SLIDER\">6</field></shadow></value><value name=\"duration\"><shadow type=\"timePicker\"><field name=\"ms\">600</field></shadow></value><next><block type=\"hudChangeLifeBy\"><data>{\"commentRefs\":[],\"fieldData\":{}}</data><value name=\"value\"><shadow type=\"math_number\"><field name=\"NUM\">-1</field></shadow></value></block></next></block></next></block></statement></block></xml>","main.ts":"// ============================================================================\n// --- 🛸 1. CORE ENGINE CONFIGURATION & GLOBAL STATE ---\n// ============================================================================\neffects.starField.startScreenEffect()\n\nlet playerShip = sprites.create(img`\n    . . . . . . . 2 . . . . . . . \n    . . . . . . . 2 . . . . . . . \n    . . . . . . 2 5 2 . . . . . . \n    . . . . . . 2 5 2 . . . . . . \n    . . . . . 2 2 5 2 2 . . . . . \n    . . . . . 2 8 5 8 2 . . . . . \n    . . . . 2 2 8 5 8 2 2 . . . . \n    . . . . 2 8 8 5 8 8 2 . . . . \n    . . . 2 2 8 8 5 8 8 2 2 . . . \n    . . 2 2 2 8 8 8 8 8 2 2 2 . . \n    . . 2 5 2 8 8 8 8 8 2 5 2 . . \n    . 2 2 5 2 2 2 2 2 2 2 5 2 2 . \n    . 2 5 5 5 2 . . . 2 5 5 5 2 . \n    2 2 2 2 2 2 . . . 2 2 2 2 2 2 \n    2 . . . . . . . . . . . . . 2 \n    . . . . . . . . . . . . . . . \n`, SpriteKind.Player)\n\nplayerShip.setPosition(80, 110)\ncontroller.moveSprite(playerShip, 120, 120)\nplayerShip.setStayInScreen(true)\n\ninfo.setLife(3)\ninfo.setScore(0)\n\n// Game State Architecture\nlet scrapInventory = 0\nlet weaponLevel = 1\nlet weaponHeat = 0\nlet coolingRate = 1\nlet isOverheated = false\nlet empCharge = 0\nlet maxEmp = 100\n\n// Custom Sprite Kinds \nnamespace SpriteKind {\n    export const AlienScout = SpriteKind.create()\n    export const ScrapMetal = SpriteKind.create()\n}\n\n// ============================================================================\n// --- 🔫 2. MODERNIZED WEAPON SYSTEMS ---\n// ============================================================================\nfunction fireLaser(xOffset: number, vx: number, vy: number) {\n    let laser = sprites.createProjectileFromSide(img`\n        . . 4 4 . . \n        . 4 5 5 4 . \n        . 4 5 5 4 . \n        . . 4 4 . . \n    `, vx, vy)\n    laser.setPosition(playerShip.x + xOffset, playerShip.y - 6)\n}\n\ncontroller.A.onEvent(ControllerButtonEvent.Pressed, function () {\n    if (isOverheated) {\n        music.play(music.melodyPlayable(music.baDing), music.PlaybackMode.UntilDone)\n        return\n    }\n\n    if (weaponLevel == 1) {\n        fireLaser(0, 0, -180)\n        weaponHeat += 12\n    } else if (weaponLevel == 2) {\n        fireLaser(-6, 0, -180)\n        fireLaser(6, 0, -180)\n        weaponHeat += 18\n    } else if (weaponLevel >= 3) {\n        fireLaser(0, 0, -180)\n        fireLaser(-6, -40, -170)\n        fireLaser(6, 40, -170)\n        weaponHeat += 25\n    }\n\n    music.play(music.melodyPlayable(music.pewPew), music.PlaybackMode.InBackground)\n\n    if (weaponHeat >= 100) {\n        isOverheated = true\n    }\n})\n\ncontroller.B.onEvent(ControllerButtonEvent.Pressed, function () {\n    if (empCharge >= maxEmp) {\n        empCharge = 0\n        music.play(music.melodyPlayable(music.sonar), music.PlaybackMode.UntilDone)\n        scene.cameraShake(8, 500)\n\n        let enemies = sprites.allOfKind(SpriteKind.Enemy)\n        let aliens = sprites.allOfKind(SpriteKind.AlienScout)\n\n        for (let target of enemies) {\n            target.destroy(effects.disintegrate, 300)\n            info.changeScoreBy(5)\n        }\n        for (let target of aliens) {\n            target.destroy(effects.disintegrate, 300)\n            info.changeScoreBy(15)\n        }\n        game.splash(\"EMP WAVE CLEARED SECTOR\")\n    } else {\n        game.splash(\"EMP CHARGE ONLY: \" + empCharge + \"%\")\n    }\n})\n\n// ============================================================================\n// --- ⚙️ 3. TICK CONTROLLERS & ENGINE RENDER LOOP ---\n// ============================================================================\ngame.onUpdate(function () {\n    if (weaponHeat > 0) {\n        weaponHeat -= coolingRate\n    }\n    if (isOverheated && weaponHeat <= 0) {\n        isOverheated = false\n    }\n\n    // AI Tracking logic\n    let activeAliens = sprites.allOfKind(SpriteKind.AlienScout)\n    for (let alien of activeAliens) {\n        if (alien.x < playerShip.x) {\n            alien.vx = 40\n        } else if (alien.x > playerShip.x) {\n            alien.vx = -40\n        }\n    }\n})\n\n// NEW: Draws the heat status directly on the screen without using extensions!\nscreen.onDraw(function () {\n    if (isOverheated) {\n        screen.print(\"OVERHEAT!!\", 5, 110, 2) // Blinks red text\n    } else {\n        screen.print(\"HEAT: \" + weaponHeat + \"%\", 5, 110, 5) // Green diagnostic text\n    }\n    screen.print(\"EMP: \" + empCharge + \"%\", 110, 110, 9) // Blue EMP layout stats\n})\n\n// ============================================================================\n// --- ☄️ 4. SPAWNING ARRAY & SCALING FACTOR MANAGERS ---\n// ============================================================================\ngame.onUpdateInterval(400, function () {\n    let scalar = Math.floor(info.score() / 100) * 12\n    let rolloutChance = randint(1, 100)\n\n    if (rolloutChance <= 65) {\n        let meteor = sprites.createProjectileFromSide(img`\n            . . . . c c c c . . . . \n            . . c c d d d d c c . . \n            . c d d d d d d d d c . \n            c d d f d d d d d d d c \n            c d d f d d d d f d d c \n            c d d d d d d d f f d c \n            c d d d d d d d d d d c \n            . c d d f f d d d d c . \n            . . c d d d d d d c . . \n            . . . . c c c c . . . . \n        `, randint(-20, 20), 80 + scalar)\n        meteor.x = randint(8, 152)\n        meteor.setKind(SpriteKind.Enemy)\n\n    } else if (rolloutChance <= 90) {\n        let alien = sprites.createProjectileFromSide(img`\n            . . . . . . 9 9 . . . . . . \n            . . . . . 9 2 2 9 . . . . . \n            . . . . 9 2 2 2 2 9 . . . . \n            . . . 9 9 2 2 2 2 9 9 . . . \n            . 9 9 9 a 2 2 2 2 a 9 9 9 . \n            9 2 2 2 a a a a a a 2 2 2 9 \n            9 9 9 9 9 9 2 2 9 9 9 9 9 9 \n            . . . . . 9 2 2 9 . . . . . \n        `, 0, 60 + (scalar * 0.5))\n        alien.x = randint(15, 145)\n        alien.setKind(SpriteKind.AlienScout)\n    }\n})\n\n// ============================================================================\n// --- 💥 5. DETAILED DISCRETE COLLISION ROUTINES ---\n// ============================================================================\nsprites.onOverlap(SpriteKind.Projectile, SpriteKind.Enemy, function (laser, meteor) {\n    laser.destroy()\n    meteor.destroy(effects.disintegrate, 150)\n    info.changeScoreBy(10)\n    empCharge = Math.min(empCharge + 4, maxEmp)\n\n    if (percentChance(25)) {\n        let scrap = sprites.create(img`\n            . . . . . . . . \n            . . . 5 5 . . . \n            . . 5 c c 5 . . \n            . 5 c c c c 5 . \n            . . 5 c c 5 . . \n            . . . 5 5 . . . \n            . . . . . . . . \n        `, SpriteKind.ScrapMetal)\n        scrap.setPosition(meteor.x, meteor.y)\n        scrap.vy = 40\n    }\n})\n\nsprites.onOverlap(SpriteKind.Projectile, SpriteKind.AlienScout, function (laser, alien) {\n    laser.destroy()\n    alien.destroy(effects.fire, 200)\n    info.changeScoreBy(25)\n    empCharge = Math.min(empCharge + 10, maxEmp)\n})\n\nsprites.onOverlap(SpriteKind.Player, SpriteKind.ScrapMetal, function (player, scrap) {\n    scrap.destroy()\n    scrapInventory += 1\n    music.play(music.melodyPlayable(music.powerUp), music.PlaybackMode.InBackground)\n})\n\nfunction checkHullDamage(threat: Sprite) {\n    threat.destroy(effects.fire, 250)\n    scene.cameraShake(6, 400)\n    music.play(music.melodyPlayable(music.bigExplosion), music.PlaybackMode.InBackground)\n    info.changeLifeBy(-1)\n}\n\nsprites.onOverlap(SpriteKind.Player, SpriteKind.Enemy, function (player, meteor) {\n    checkHullDamage(meteor)\n})\n\nsprites.onOverlap(SpriteKind.Player, SpriteKind.AlienScout, function (player, alien) {\n    checkHullDamage(alien)\n})\n\n// ============================================================================\n// --- 🛒 6. GAME INTERFACE: THE SCRAP SHOP SYSTEM ---\n// ============================================================================\ncontroller.menu.onEvent(ControllerButtonEvent.Pressed, function () {\n    let choice = game.askForString(\n        \"SCRAP: \" + scrapInventory + \" | WP_LVL: \" + weaponLevel + \"\\\\n1:Up Weapon(5s) 2:Hull(3s) 3:Cool(2s)\", 1\n    )\n\n    if (choice == \"1\") {\n        if (scrapInventory >= 5) {\n            scrapInventory -= 5\n            weaponLevel += 1\n            game.splash(\"WEAPON UPGRADED!\")\n        } else {\n            game.splash(\"NOT ENOUGH SCRAP\")\n        }\n    } else if (choice == \"2\") {\n        if (scrapInventory >= 3) {\n            scrapInventory -= 3\n            info.changeLifeBy(1)\n            game.splash(\"HULL STRUCT SECURED\")\n        } else {\n            game.splash(\"NOT ENOUGH SCRAP\")\n        }\n    } else if (choice == \"3\") {\n        if (scrapInventory >= 2) {\n            scrapInventory -= 2\n            coolingRate += 1\n            game.splash(\"COOLING SPEED INCREASED\")\n        } else {\n            game.splash(\"NOT ENOUGH SCRAP\")\n        }\n    }\n})\n","README.md":" ","assets.json":"","til